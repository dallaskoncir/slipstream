    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "ai": "^7.0.29",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "isolated-vm": "6.1.2",
    "ollama-ai-provider-v2": "4.0.1",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
