{
  "name": "slipstream",
  "version": "0.1.0",
  "description": "Multi-agent PR review orchestrator CLI",
  "type": "module",
  "bin": {
    "slipstream": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
