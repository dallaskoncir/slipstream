{
  "name": "@flowlaps/scrutineer",
  "version": "0.1.0",
  "description": "Multi-agent PR review orchestrator CLI",
  "type": "module",
  "license": "MIT",
  "author": "Dallas Koncir",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dallaskoncir/scrutineer.git"
  },
  "homepage": "https://github.com/dallaskoncir/scrutineer#readme",
  "bugs": {
    "url": "https://github.com/dallaskoncir/scrutineer/issues"
  },
  "keywords": [
    "cli",
    "code-review",
    "ai",
    "llm",
    "pr-review",
    "security-audit",
    "ts-morph"
  ],
  "bin": {
    "scrutineer": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --experimental-test-module-mocks --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@clack/prompts": "1.7.0",
    "ai": "^7.0.29",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "isolated-vm": "6.1.2",
    "ollama-ai-provider-v2": "4.0.1",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
