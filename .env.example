ANTHROPIC_API_KEY=

# Only needed for `scrutineer review --pr <number>`
GITHUB_TOKEN=

# Optional: override the default model per provider (claude-sonnet-5 / qwen2.5-coder:7b).
# For --provider ollama, leaving this unset auto-detects whatever model is currently
# loaded (or, failing that, pulled) on the target Ollama server instead.
# SCRUTINEER_MODEL_ANTHROPIC=
# SCRUTINEER_MODEL_OLLAMA=

# Optional: same convention the `ollama` CLI itself uses. Only needed if your Ollama
# server isn't on 127.0.0.1:11434 — e.g. running on Windows and reached from WSL via
# its gateway IP (find it with `cat /etc/resolv.conf` on the WSL side).
# OLLAMA_HOST=
